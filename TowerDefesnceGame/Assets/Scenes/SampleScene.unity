  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::CatProfileCard
  catRoster:
  - catName: 'Sir Laserpaws  '
    towerType: LaserEyeCat
    personality: Focused
    catchphrase: '"I never miss."  '
    portrait: {fileID: -7436059541796452876, guid: e58ec274fb1332e40b7eba0a41087266, type: 3}
    totalKills: 0
    level: 0
  - catName: Boxsworth
    towerType: CardboardBoxCat
    personality: Sneaky
    catchphrase: '"They never see me coming."  '
    portrait: {fileID: -7436059541796452876, guid: e58ec274fb1332e40b7eba0a41087266, type: 3}
    totalKills: 0
    level: 0
  - catName: 'Lord Fluffington  '
    towerType: ChonkCat
    personality: Lazy
    catchphrase: '"Why run when you can sit?"  '
    portrait: {fileID: -7436059541796452876, guid: e58ec274fb1332e40b7eba0a41087266, type: 3}
    totalKills: 0
    level: 0
  - catName: 'General Grumpkins  '
    towerType: GrumpyCat
    personality: Grumpy
    catchphrase: '"Everything is terrible."  '
    portrait: {fileID: -7436059541796452876, guid: e58ec274fb1332e40b7eba0a41087266, type: 3}
    totalKills: 0
    level: 0
  - catName: 'The Kitten Squad  '
    towerType: KittenSwarm
    personality: Playful
    catchphrase: '"We are many. We are loud."  '
    portrait: {fileID: -7436059541796452876, guid: e58ec274fb1332e40b7eba0a41087266, type: 3}
    totalKills: 0
    level: 0
  - catName: Shadow
    towerType: NinjaCat
    personality: Aggressive
    catchphrase: '"..."'
    portrait: {fileID: -7436059541796452876, guid: e58ec274fb1332e40b7eba0a41087266, type: 3}
    totalKills: 0
    level: 0
  - catName: 'Professor Whiskers  '
    towerType: WizardCat
    personality: Eccentric
    catchphrase: '"The spell chooses the cat!"  '
    portrait: {fileID: -7436059541796452876, guid: e58ec274fb1332e40b7eba0a41087266, type: 3}
    totalKills: 0
    level: 0
  - catName: 'Mr Tibbles  '
    towerType: PrinterCat
    personality: Anxious
    catchphrase: '"WAS THAT THE PRINTER?!"  '
    portrait: {fileID: -7436059541796452876, guid: e58ec274fb1332e40b7eba0a41087266, type: 3}
    totalKills: 0
    level: 0
  - catName: 'Mr Tibbles  '
    towerType: PrinterCat
    personality: Anxious
    catchphrase: '"WAS THAT THE PRINTER?!"  '
    portrait: {fileID: -7436059541796452876, guid: e58ec274fb1332e40b7eba0a41087266, type: 3}
    totalKills: 0
    level: 0
  - catName: Yarnella
    towerType: YarnBallTower
    personality: Playful
    catchphrase: '"Catch! ...please give it back."  '
    portrait: {fileID: -7436059541796452876, guid: e58ec274fb1332e40b7eba0a41087266, type: 3}
    totalKills: 0
    level: 0
  - catName: 'Baron Napsworth  '
    towerType: CatTreeTower
    personality: Lazy
    catchphrase: '"Wake me when it''s important."  '
    portrait: {fileID: -7436059541796452876, guid: e58ec274fb1332e40b7eba0a41087266, type: 3}
    totalKills: 0
    level: 0
  - catName: Sage
